        </mxCell>
        <mxCell id="blocked" value="BLOCKED&#10;final qa-report attached,&#10;human message, end turn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="660" y="700" width="200" height="70" as="geometry" />
