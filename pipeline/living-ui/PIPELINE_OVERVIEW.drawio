        <mxCell id="qd2" value="yes — re-enter at failed gate,&#10;re-run it + all downstream" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="dLoop" target="g1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="980" y="585" /><mxPoint x="980" y="150" /><mxPoint x="280" y="150" /></Array></mxGeometry></mxCell>
