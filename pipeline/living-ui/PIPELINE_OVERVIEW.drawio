        <mxCell id="qf6" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d79b00;" edge="1" parent="1" source="g6" target="fix"><mxGeometry relative="1" as="geometry" /></mxCell>
