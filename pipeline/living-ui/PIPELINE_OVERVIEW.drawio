        <mxCell id="qe5" value="pass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="g5" target="g6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="qe6" value="pass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="g6" target="g7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="qe7" value="pass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="g7" target="g8"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="qe8" value="audit green" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="g8" target="pass"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="qf8" value="audit fails: fix + re-audit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d79b00;" edge="1" parent="1" source="g8" target="fix"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="qf1" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d79b00;" edge="1" parent="1" source="g1" target="fix"><mxGeometry relative="1" as="geometry" /></mxCell>
