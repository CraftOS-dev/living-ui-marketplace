        <mxCell id="qf3" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d79b00;" edge="1" parent="1" source="g3" target="fix"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="qf4" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d79b00;" edge="1" parent="1" source="g4" target="fix"><mxGeometry relative="1" as="geometry" /></mxCell>
