    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="20" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1250" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="qaTitle" value="QA gate loop — QA_GATES.md (run by the creation runner, Claude Code, from CREATION C5 and IMPROVEMENT I5, identically)" style="text;html=1;align=left;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="20" width="900" height="30" as="geometry" />
        </mxCell>

        <mxCell id="setup" value="Setup: python setup_local.py (placeholders now dirty),&#10;pip install -r backend/requirements.txt, npm install" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="120" y="70" width="320" height="60" as="geometry" />
        </mxCell>

        <mxCell id="g1" value="G1  pytest tests/&#10;0 failures, test_example.py deleted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="120" y="170" width="320" height="55" as="geometry" />
        </mxCell>
        <mxCell id="g2" value="G2  test_runner.py --internal&#10;ALL TESTS PASSED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="120" y="265" width="320" height="55" as="geometry" />
        </mxCell>
        <mxCell id="g3" value="G3  test_runner.py --unit&#10;ALL TESTS PASSED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="120" y="360" width="320" height="55" as="geometry" />
        </mxCell>
        <mxCell id="g4" value="G4  npm run build&#10;exit 0, zero TS errors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="120" y="455" width="320" height="55" as="geometry" />
        </mxCell>
        <mxCell id="g5" value="G5  fresh DB → uvicorn up → test_runner.py --external&#10;test_results.json: status=pass, errors=[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="120" y="550" width="320" height="55" as="geometry" />
        </mxCell>
        <mxCell id="g6" value="G6  real-browser pass (Playwright)&#10;console clean · init OK · CRUD per entity + reload persistence ·&#10;360/768/1280 px · empty states · loading · contrast 4.5:1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="120" y="645" width="320" height="75" as="geometry" />
        </mxCell>
        <mxCell id="g7" value="G7  adversarial review (strict PM)&#10;SPEC criteria + STANDARDS blocking list + VERIFY §2–6 +&#10;SPEC §9 amendments honored · zero BLOCKER, zero MAJOR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="120" y="760" width="320" height="70" as="geometry" />
        </mxCell>

        <mxCell id="g8" value="G8  restore to base IMPORT-READY state + audit&#10;stop servers · delete node_modules/dist/db/uploads/caches ·&#10;revert placeholders · audit: placeholders intact, no artifacts, size sane" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="120" y="880" width="320" height="75" as="geometry" />
        </mxCell>

        <mxCell id="pass" value="ALL GATES PASS&#10;(thumbnail captured during final G6; folder imports&#10;into CraftBot as a fresh app) → AWAITING_HUMAN_REVIEW" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="120" y="1000" width="320" height="70" as="geometry" />
        </mxCell>

        <mxCell id="fix" value="Diagnose: backend/logs first,&#10;then TROUBLESHOOTING.md.&#10;Fix test-first.&#10;Write qa-report-n + log line." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="640" y="380" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="dLoop" value="iteration ≤ 5&#10;and not 2-strike?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
