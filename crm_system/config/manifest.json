{
  "id": "f3a1b8c2",
  "name": "CRM System",
  "version": "1.0.0",
  "description": "Comprehensive CRM system with contacts, companies, deals pipeline, AI-powered lead scoring, email generation, sales forecasting, SMTP email, campaigns, and full reporting",
  "author": "CraftBot Agent",
  "livingUIVersion": "1.0",
  "features": [],
  "createdAt": "2026-04-05T00:00:00Z",
  "entrypoint": {
    "frontend": "src/main.tsx",
    "backend": "backend/main.py"
  },
  "ports": {
    "frontend": 3112,
    "backend": 3113
  },
  "pipeline": {
    "backend": {
      "cwd": "backend",
      "install": "pip install -r requirements.txt",
      "tests": [
        {"name": "internal", "command": "python test_runner.py --internal", "required": true},
        {"name": "unit", "command": "python test_runner.py --unit", "required": true},
        {"name": "agent_tests", "command": "python -m pytest tests/ -v --tb=short", "required": true},
        {"name": "compatibility", "command": "python test_runner.py --compatibility", "required": false}
      ],
      "start": "python -m uvicorn main:app --host 0.0.0.0 --port 3113",
      "health": "http://localhost:3113/health",
      "post_start_tests": [
        {"name": "external", "command": "python test_runner.py --external --port 3113", "required": false}
      ]
    },
    "frontend": {
      "cwd": ".",
      "install": "npm install",
      "build": "npm run build",
      "start": "npm run preview -- --port 3112",
      "health": null
    }
  },
  "agentAwareness": {
    "enabled": true,
    "stateReportInterval": 1000,
    "reportComponents": true,
    "reportUserInputs": true,
    "reportVisibleText": true
  },
  "theme": "system"
}
